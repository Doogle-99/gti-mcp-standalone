# Google Threat Intelligence MCP Server Configuration

# Google Cloud Project ID (find it at: https://console.cloud.google.com)
PROJECT_ID="your-gcp-project-id"

# Name for your Cloud Run service
SERVICE_NAME="gti-remotemcp-server"

# Preferred Google Cloud region (e.g., us-central1, europe-west1)
REGION="us-central1"

# Secure authentication token for MCP server access (X-Mcp-Authorization)
# If left blank, the deployment script will generate one for you.
MCP_AUTH_TOKEN=""
